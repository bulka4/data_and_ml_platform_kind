name: mlflow-test

entry_points:
  train:
    parameters:
      fit_intercept:
        type: bool
        default: True
      positive: 
        type: bool
        default: True
    command: "python3 train.py --fit_intercept {fit_intercept} --positive {positive}"

  evaluate:
    parameters:
      # We will evaluate the model from the latest run from the experiment specified by the experiment_name parameter.
      experiment_name:
        type: string
        default: lasso_test
    command: "python3 evaluate.py --experiment_name {experiment_name}"
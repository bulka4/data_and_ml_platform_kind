name: mlflow-test

entry_points:
  train:
    parameters:
      fit_intercept:
        type: bool
        default: True
      positive: 
        type: bool
        default: True
      model_name:
        type: string
    command: "python3 train.py --fit_intercept {fit_intercept} --positive {positive} --model_name {model_name}"

  evaluate:
    command: "python3 evaluate.py"